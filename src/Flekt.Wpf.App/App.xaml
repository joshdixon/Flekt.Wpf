<Application x:Class="Flekt.Wpf.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Flekt.Wpf.App.Converters"
             Startup="Application_Startup">
    <Application.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- Inverse bool converter for IsEnabled bindings -->
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="2"
                          Direction="270" Color="#000000" Opacity="0.15"/>
    </Application.Resources>
</Application>
