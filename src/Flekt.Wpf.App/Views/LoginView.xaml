<UserControl x:Class="Flekt.Wpf.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Flekt.Wpf.App.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </UserControl.Resources>

    <Grid Background="#F0F0F0">
        <Border Background="White" CornerRadius="8" Padding="40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="350" MaxWidth="400"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <!-- Logo / Title -->
                <TextBlock Text="Flekt Warehouse" FontSize="24" FontWeight="Bold"
                           Foreground="#0078D4" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Management System" FontSize="14" Foreground="#666"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" Foreground="#333" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8" FontSize="14" Margin="0,0,0,15"
                         IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" Foreground="#333" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Padding="8" FontSize="14" Margin="0,0,0,20"
                             IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"/>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontSize="12"
                           TextWrapping="Wrap" Margin="0,0,0,10"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>

                <!-- Loading spinner -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="4" Margin="0,0,10,0"/>
                    <TextBlock Text="Signing in..." Foreground="#666" FontSize="12"/>
                </StackPanel>

                <!-- Sign In button -->
                <Button Content="Sign In" Command="{Binding LoginCommand}"
                        IsDefault="True"
                        Padding="12,10" FontSize="14" FontWeight="SemiBold"
                        Background="#0078D4" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="{Binding LoginButtonMargin}"
                        Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
