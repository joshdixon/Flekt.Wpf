<UserControl x:Class="Flekt.Wpf.App.Views.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Flekt.Wpf.App.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="FilterTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Stock Inventory" FontSize="20" FontWeight="SemiBold"
                   Foreground="#333" Margin="0,0,0,12"/>

        <!-- Search bar + Group by -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8" FontSize="13" VerticalContentAlignment="Center">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}"
                    Padding="12,8" Margin="8,0,0,0" FontSize="13"/>
            <Button Grid.Column="2" Content="Refresh" Command="{Binding LoadStockCommand}"
                    Padding="12,8" Margin="8,0,0,0" FontSize="13"/>

            <TextBlock Grid.Column="3" Text="Group by:" VerticalAlignment="Center"
                       FontSize="12" Foreground="#666" Margin="16,0,6,0"/>
            <ComboBox Grid.Column="4" ItemsSource="{Binding GroupByOptions}"
                      SelectedItem="{Binding GroupByColumn}"
                      Width="110" FontSize="12" VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Column filter row -->
        <Border Grid.Row="2" Background="#F0F4F8" BorderBrush="#DDD" BorderThickness="1,1,1,0"
                Padding="4,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding FilterSku, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FilterTextBox}" Margin="0,0,4,0">
                    <TextBox.Tag>SKU</TextBox.Tag>
                </TextBox>
                <TextBox Grid.Column="1" Text="{Binding FilterName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FilterTextBox}" Margin="0,0,4,0"/>
                <ComboBox Grid.Column="2" SelectedItem="{Binding FilterCategory}"
                          ItemsSource="{Binding AvailableCategories}"
                          FontSize="12" Margin="0,0,4,0" VerticalContentAlignment="Center"/>
                <!-- Quantity — no filter -->
                <TextBlock Grid.Column="3" Text="" Margin="4,0"/>
                <TextBox Grid.Column="4" Text="{Binding FilterLocation, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FilterTextBox}" Margin="0,0,4,0"
                         Visibility="{Binding DataContext.ShowLocationColumn, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                <!-- Unit Price — no filter -->
                <TextBlock Grid.Column="5" Text="" Margin="4,0"/>
                <!-- Last Updated — no filter -->
                <TextBlock Grid.Column="6" Text="" Margin="4,0"/>
                <Button Grid.Column="7" Content="Clear" Command="{Binding ClearFiltersCommand}"
                        Padding="8,3" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- Loading indicator -->
        <ProgressBar Grid.Row="4" IsIndeterminate="True" Height="4"
                     VerticalAlignment="Top" Margin="0,0,0,8"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <!-- Data Grid -->
        <DataGrid Grid.Row="4" ItemsSource="{Binding StockView}"
                  SelectedItem="{Binding SelectedStockItem}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  AlternatingRowBackground="#F8F8F8" RowHeight="32"
                  ColumnHeaderHeight="36" FontSize="13"
                  BorderThickness="1" BorderBrush="#DDD"
                  Margin="0,4,0,0">

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Adjust Stock" Command="{Binding AdjustStockCommand}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <!-- Group header style -->
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <Expander IsExpanded="True">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                               Foreground="#0078D4" Margin="0,0,8,0"/>
                                                    <TextBlock FontSize="12" Foreground="#888">
                                                        <Run Text="("/>
                                                        <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                                                        <Run Text=" items)"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Expander.Header>
                                            <ItemsPresenter/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="110"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110"/>
                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="LocationColumn" Header="Location" Binding="{Binding Location}" Width="90"
                                    Visibility="{Binding DataContext.ShowLocationColumn, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=C2}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Last Updated" Binding="{Binding LastUpdated, StringFormat=g}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <TextBlock Grid.Row="5" Text="{Binding StatusText}" Foreground="#666" FontSize="12" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
