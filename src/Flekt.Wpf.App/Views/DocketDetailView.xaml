<UserControl x:Class="Flekt.Wpf.App.Views.DocketDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Flekt.Wpf.App.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Back button + Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="&lt; Back" Command="{Binding GoBackCommand}"
                    Padding="12,6" FontSize="13" VerticalAlignment="Center"/>
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#333"
                       VerticalAlignment="Center" Margin="16,0,0,0">
                <Run Text="Docket #"/><Run Text="{Binding Docket.Id, Mode=OneWay}"/>
            </TextBlock>
        </StackPanel>

        <!-- Info panel -->
        <Border Grid.Row="1" Background="#F0F4F8" Padding="12" Margin="0,0,0,12"
                BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Sender:" FontWeight="SemiBold" Margin="0,0,8,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Docket.Sender}" Margin="0,0,24,4"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Status:" FontWeight="SemiBold" Margin="0,0,8,4"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Docket.Status}" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Receiver:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Docket.Receiver}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Created:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Docket.CreatedAt, StringFormat=g}"/>
            </Grid>
        </Border>

        <!-- Loading indicator -->
        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="4" Margin="0,0,0,8"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <!-- Lines DataGrid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Lines}"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  AlternatingRowBackground="#F8F8F8" RowHeight="32"
                  ColumnHeaderHeight="36" FontSize="13"
                  BorderThickness="1" BorderBrush="#DDD"
                  CanUserAddRows="False" CanUserDeleteRows="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Qty Requested" Binding="{Binding QuantityRequested}" Width="110" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Location" Binding="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"
                                    IsReadOnly="{Binding DataContext.IsEditable, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBool}}"/>
                <DataGridTextColumn Header="Allocated Qty" Binding="{Binding AllocatedQty}" Width="110" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Allocate" Command="{Binding AllocateCommand}"
                    IsEnabled="{Binding CanAllocate}"
                    Padding="16,8" FontSize="13" Margin="0,0,8,0"/>
            <Button Content="Confirm" Command="{Binding ConfirmCommand}"
                    IsEnabled="{Binding CanConfirm}"
                    Padding="16,8" FontSize="13" Margin="0,0,8,0"/>
            <Button Content="Cancel Docket" Command="{Binding CancelCommand}"
                    IsEnabled="{Binding CanCancel}"
                    Padding="16,8" FontSize="13" Foreground="#C00"/>
        </StackPanel>

        <!-- Status bar -->
        <TextBlock Grid.Row="5" Text="{Binding StatusText}" Foreground="#666" FontSize="12" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
