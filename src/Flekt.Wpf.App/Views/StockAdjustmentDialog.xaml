<Window x:Class="Flekt.Wpf.App.Views.StockAdjustmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Flekt.Wpf.App.Converters"
        Title="Adjust Stock" Height="340" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Item info (read-only) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#333">
                <Run Text="{Binding Sku, Mode=OneWay}"/><Run Text=" — "/><Run Text="{Binding Name, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock FontSize="12" Foreground="#666" Margin="0,4,0,0">
                <Run Text="Location: "/><Run Text="{Binding Location, Mode=OneWay}"/>
                <Run Text="    Current Qty: "/><Run Text="{Binding CurrentQuantity, Mode=OneWay}" FontWeight="Bold"/>
            </TextBlock>
        </StackPanel>

        <Separator Grid.Row="1" Margin="0,0,0,12"/>

        <!-- Adjustment quantity -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Adjustment (+/-):" VerticalAlignment="Center" FontSize="13"/>
            <TextBox Grid.Column="1" Text="{Binding AdjustmentQuantity, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" FontSize="13" VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Reason -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Reason:" VerticalAlignment="Top" FontSize="13" Margin="0,4,0,0"/>
            <TextBox Grid.Column="1" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" FontSize="13" Height="60" TextWrapping="Wrap"
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- Error message -->
        <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}" Foreground="Red" FontSize="12"
                   Margin="0,0,0,4" TextWrapping="Wrap"/>

        <!-- Progress -->
        <ProgressBar Grid.Row="5" IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                     Visibility="{Binding IsSubmitting, Converter={StaticResource BoolToVis}}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Submit" Command="{Binding SubmitCommand}"
                    IsEnabled="{Binding IsSubmitting, Converter={StaticResource InverseBool}}"
                    Padding="16,8" FontSize="13" Margin="0,0,8,0"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}"
                    Padding="16,8" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>
